{
  "name": "backend",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon",
    "build": "CONFIG_PATH=../.env.development tsc && tsc-alias",
    "start:task:prepared-orders-email": "npm run build && CONFIG_PATH=../.env.development node ./dist/src/tasks/prepared_orders_mail/task.js",
    "start:task:overdue-email": "npm run build && CONFIG_PATH=../.env.development node ./dist/src/tasks/overdue_email/task.js",
    "start:task:backup": "npm run build && CONFIG_PATH=../.env.development node ./dist/src/tasks/backup/task.js",
    "start:server": "npm run build && CONFIG_PATH=../.env.development node ./dist/src/index.js",
    "db:seed": "npm run build && CONFIG_PATH=../.env.development npx ts-node -r tsconfig-paths/register scripts/seed-local-data.ts",
    "db:seed:overwrite": "npm run db:seed -- --overwrite",
    "run-script": "npm run build && CONFIG_PATH=../.env.development npx ts-node -r tsconfig-paths/register",
    "lint": "eslint .",
    "format": "npm run lint -- --fix && prettier --write src/",
    "test:code": "npm run build && CONFIG_PATH=../.env.development vitest run --silent",
    "test": "npm run lint && npm run test:code"
  },
  "nodemonConfig": {
    "watch": [
      "src"
    ],
    "exec": "npm run start:server",
    "ext": "ts,js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "body-parser": "^1.20.2",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "dropbox": "^10.34.0",
    "express": "^5.1.0",
    "express-basic-auth": "^1.2.1",
    "formidable": "^3.5.2",
    "morgan": "^1.10.0",
    "nodemailer": "^6.9.14",
    "pdfkit": "^0.15.0",
    "source-map-support": "^0.5.21",
    "sqlite3": "^5.1.7",
    "typeorm": "^0.3.20"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/body-parser": "^1.19.5",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/formidable": "^3.4.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.17",
    "@types/nodemailer": "^6.4.15",
    "@types/pdfkit": "^0.13.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.1.3",
    "globals": "^17.0.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.3.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
