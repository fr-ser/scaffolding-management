{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "npm run test:code && npm run lint && npm run test:type-check",
    "test:code": "vitest run",
    "test:type-check": "vue-tsc --build --force",
    "lint": "eslint .",
    "format": "npm run lint -- --fix && prettier --write src/"
  },
  "dependencies": {
    "@primeuix/themes": "^2.0.3",
    "@tailwindcss/vite": "^4.1.12",
    "axios": "^1.7.2",
    "date-fns": "^4.1.0",
    "file-saver": "^2.0.5",
    "pinia": "^3.0.1",
    "primeicons": "^7.0.0",
    "primevue": "^4.3.7",
    "tailwindcss": "^4.1.12",
    "tailwindcss-primeui": "^0.6.1",
    "vue": "^3.4.29",
    "vue-router": "^5.0.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@pinia/testing": "^1.0.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@tsconfig/node20": "^20.1.4",
    "@types/file-saver": "^2.0.7",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "autoprefixer": "^10.4.19",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^17.0.0",
    "jsdom": "^29.0.0",
    "npm-run-all2": "^8.0.0",
    "prettier": "3.3.2",
    "sass-embedded": "^1.85.0",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.0",
    "vitest": "^4.0.0",
    "vue-tsc": "^3.0.0"
  }
